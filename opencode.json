{
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"],
      "initialization": {
        "rust-analyzer.checkOnSave": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.features": "all",
        "rust-analyzer.diagnostics.enable": true,
        "rust-analyzer.inlayHints.enable": true
      }
    }
  }
}
